# ============================================
# TopupApi - Environment Variables
# ============================================
# Copy this file to .env (local dev) or .env.production (Docker) and fill in
# real values. Never commit the filled-in file.

# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=3000

# Comma-separated list of origins allowed to call this API from a browser,
# e.g. the TopupApp frontend. No wildcard support on purpose — list every
# origin explicitly.
CORS_ORIGIN=https://mobiletopup.planettalk.com

# ============================================
# Database (PostgreSQL, self-hosted container — see docker-compose.yml)
# ============================================
DATABASE_URL=postgresql://postgres:your_secure_password@postgres:5432/topupApiDB?sslmode=disable
POSTGRES_DB=topupApiDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# ============================================
# Redis (shared provider-token cache + rate-limit store — see docker-compose.yml)
# ============================================
# In Docker this is set to redis://redis:6379 by compose. If unset, provider
# token caching falls back to per-request fetches and rate limiting falls back
# to in-memory (fine for a single instance / local dev).
REDIS_URL=redis://redis:6379

# ============================================
# Providers (Reloadly + buhibab/PlanetTalk) — ported from TopupApp
# ============================================
# Reloadly (global top-up / gift-card / utility provider)
RELOADLY_SANDBOX=false
RELOADLY_CLIENT_ID=your_reloadly_client_id
RELOADLY_CLIENT_SECRET=your_reloadly_client_secret
RELOADLY_BALANCE_ALERT_THRESHOLD=50

# buhibab ("PlanetTalk") — Nigeria-only provider
PLANETTALK_API_URL=https://api.buhibab.com
PLANETTALK_EMAIL=your_planettalk_email
PLANETTALK_PASSWORD=your_planettalk_password

# Route Nigeria top-ups/utilities through 'planettalk' (buhibab) or 'reloadly'.
TOPUP_PROVIDER_NG=reloadly

# ============================================
# Admin auth (login-gated admin panel)
# ============================================
# JWT signing secret for admin sessions. Generate: openssl rand -hex 32
JWT_SECRET=change-me-generate-a-strong-secret
JWT_EXPIRES_IN=12h
# Static bearer token for machine-to-machine endpoints only (balance-alert cron).
# Generate: openssl rand -hex 32
ADMIN_API_TOKEN=change-me-generate-a-strong-token

# First-admin seed (used by: npx ts-node prisma/seed-admin.ts). Safe to unset
# after the first run; re-running resets that admin's password.
ADMIN_SEED_EMAIL=admin@planettalk.com
ADMIN_SEED_PASSWORD=change-me-strong-password
ADMIN_SEED_NAME=Ops Admin

# ============================================
# Alerting (ops notifications) — both channels optional/no-op if unset
# ============================================
# Slack/Discord incoming webhook (fulfilment failures, low balance, disputes)
RELOADLY_ALERT_WEBHOOK_URL=
# Mailgun (EU API) for email alerts — creds shared with AgentPortalBackend
MAILGUN_API_KEY=
MAILGUN_DOMAIN=www.planettalk.com
MAILGUN_API_URL=https://api.eu.mailgun.net
MAILGUN_FROM_EMAIL=PlanetTalk TopUp <marketing@planettalk.com>
# Comma-separated ops recipients for email alerts
OPS_ALERT_EMAILS=
